{
  "name": "angehlang-universe-os-13",
  "private": true,
  "version": "13.0.0",
  "description": "Sovereign Omni-Prime AI Operating System — 100% Offline-Sovereign Architecture.",
  "type": "module",
  "scripts": {
    "dev": "webpack serve --mode development",
    "build": "webpack --mode production",
    "build:analyze": "webpack --mode production --env analyze=true",
    "preview": "npm run build && node server.mjs preview",
    "preview:hot": "concurrently \"webpack --mode production --watch\" \"node server.mjs preview\"",
    "serve": "node server.mjs preview",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist",
    "test:studios": "npx ts-node -r tsconfig-paths/register run-studio-tests.ts",
    "commit:sovereign": "git add -A && git commit -m \"feat: Complete Trillion-X Super-Intelligence (surpasses ALL LLMs + humans) [auto]\"",
    "deploy": "npm run build && npm run commit:sovereign",
    "system-check": "node -e \"import('./src/agents/AIImprovementSuggester.ts').then(m => { const s = m.AIImprovementSuggester.getInstance(); s.generateSystemImprovementPlan().then(p => { console.log(JSON.stringify(p, null, 2)); }); })\"",
    "recreate": "node recreate.mjs",
    "setup-hooks": "git config core.hooksPath .git-hooks",
    "deps:check": "node -e \"import('./src/agents/DepChecker.ts').then(m => { const c = m.DepChecker.getInstance(); c.verifyDependencies().then(r => { console.log(JSON.stringify(r, null, 2)); }); })\"",
    "audit:cores": "npx ts-node -r tsconfig-paths/register audit_native_cores.ts",
    "training": "npx ts-node -r tsconfig-paths/register scripts/train.ts",
    "stress-test": "npx ts-node -r tsconfig-paths/register scripts/stress-test.ts",
    "archive": "npx ts-node -r tsconfig-paths/register scripts/archive.ts"
  },
  "dependencies": {
    "@ai-sdk/deepseek": "^2.0.29",
    "clsx": "^2.1.1",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "idb-keyval": "^6.2.2",
    "lucide-react": "^0.546.0",
    "motion": "^12.38.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-markdown": "^10.1.0",
    "tailwind-merge": "^3.5.0",
    "three": "^0.183.2",
    "tone": "^15.0.4",
    "uuid": "^14.0.0"
  },
  "devDependencies": {
    "@esbuild/win32-x64": "^0.19.12",
    "@svgr/webpack": "^8.1.0",
    "@swc/core": "^1.10.15",
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "autoprefixer": "^10.4.17",
    "compression-webpack-plugin": "^12.0.0",
    "concurrently": "^9.2.1",
    "copy-webpack-plugin": "^14.0.0",
    "css-loader": "^6.10.0",
    "css-minimizer-webpack-plugin": "^8.0.0",
    "esbuild": "^0.28.0",
    "esbuild-loader": "^4.4.3",
    "html-webpack-plugin": "^5.6.0",
    "postcss": "^8.4.35",
    "postcss-loader": "^8.1.0",
    "style-loader": "^3.3.4",
    "svgo-loader": "^5.0.0",
    "tailwindcss": "^3.4.1",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.7.3",
    "webpack": "^5.90.0",
    "webpack-bundle-analyzer": "^4.10.1",
    "webpack-cli": "^5.1.4",
    "webpack-dev-server": "^5.0.0"
  }
}
