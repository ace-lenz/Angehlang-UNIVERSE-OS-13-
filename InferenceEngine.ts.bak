const ANGEH_QUANTUM_PATH = 'c:\\Users\\Lenon\\Desktop\\angeh llm\\angehlang-universe-os\\Angehlang_Universe_OS_v4.0';

const OLLAMA_HOST = 'http://localhost:11434';

const getEnv = (key: string, fallback = ''): string => {
  if (typeof window === 'undefined') return fallback;
  return (window as any).ENV?.[key] || localStorage.getItem(key.toLowerCase()) || fallback;
};

async function callLocalLLM(prompt: string): Promise<string | null> {
  try {
    const controller = new AbortController();
    const timeoutId = setTimeout(() => controller.abort(), 60000);
    
    const response = await fetch(`${OLLAMA_HOST}/api/generate`, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({
        model: 'llama3.2',
        prompt: prompt,
        stream: false,
        options: {
          temperature: 0.7,
          num_predict: 2048
        }
      }),
      signal: controller.signal
    });
    
    clearTimeout(timeoutId);
    
    if (response.ok) {
      const data = await response.json();
      return data.response || null;
    }
  } catch (e) {
    console.warn('Local LLM (Ollama) unavailable:', e);
  }
  return null;
}

async function callLMStudio(prompt: string): Promise<string | null> {
  try {
    const controller = new AbortController();
    const timeoutId = setTimeout(() => controller.abort(), 60000);
    
    const response = await fetch('http://localhost:1234/v1/chat/completions', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({
        model: 'local-model',
        messages: [{ role: 'user', content: prompt }],
        temperature: 0.7,
        max_tokens: 2048
      }),
      signal: controller.signal
    });
    
    clearTimeout(timeoutId);
    
    if (response.ok) {
      const data = await response.json();
      return data.choices?.[0]?.message?.content || null;
    }
  } catch (e) {
    console.warn('LM Studio unavailable:', e);
  }
  return null;
}

async function callNativeLLM(prompt: string): Promise<string | null> {
  let result = await callLocalLLM(prompt);
  if (!result) {
    result = await callLMStudio(prompt);
  }
  return result;
}

