}

export class BaseProcessor implements Processor {
  id: string;
  
  constructor(id: string) {
    this.id = id;
  }
  
  async process(data: any): Promise<any> {
    console.log(\`[PROCESSOR:\${this.id}] Processing: \${JSON.stringify(data).substring(0, 50)}\`);
    return { processed: true, data, processor: this.id };
  }
}

