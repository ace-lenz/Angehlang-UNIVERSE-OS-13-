export async function nativeLlmInfer(prompt: string, brainStorage: Record<string, string>, files?: File[]): Promise<{ 
  response: string; 
  thinking: string[]; 
  type: Message['type']; 
  learned?: { topic: string, info: string }; 
  audioUrl?: string; 
  leadAgentId: string;
  virtualFiles?: VirtualFile[];
  plan?: Task[];
  topSelections?: CandidateResult[];
  isSearching?: boolean;
  agentScores?: ScoringAgent[];
  autonomousProcess?: AutonomousProcess;
}> {
  const startTime = Date.now();
  const promptLc = prompt.toLowerCase();
  
  // Immediate thinking feedback
  const thinking: string[] = [
    `◈ [INIT] System: ${ANGEH_QUANTUM_PATH}`,
    `◈ [INIT] Loading quantum storage...`,
    `◈ [INIT] Computing cores: ACTIVE`
  ];
  
  let onlineKnowledge: LearnResult = { source: 'cache', content: 'No external knowledge available' };
  let fileContents: FileContent[] = [];
  let topFive: ContentUnit[] = [];
  let refinedFiles: FileContent[] = [];
  let qc = { score: 0, report: [], issues: [] };
  let questions: string[] = [];
  let selectedCandidate: CandidateResult | undefined;
  let intent: Intent = { complexity: 'simple', requiresTool: null, requiresGenerator: null, subIntents: [], confidence: 1, studio: 'GENERAL' };
  let plan: Task[] = [];
  let textCorrectResult = { corrected: prompt, changes: [] as string[] };
  let mathResult = { valid: true, errors: [] as string[], corrections: [] as string[] };
  
  // Run phases with real-time updates
  try {
    // Phase 1: Best Selection
    thinking.push(`◈ [BEST_3] Running Perfectionist & Engineer scoring...`);
    const candidates = await bestOfThreeSelection(prompt);
    const selectedCandidate = candidates.find(c => c.selected) || candidates[0];
    thinking.push(`◈ [BEST_3] Selected: ${selectedCandidate?.id} (Score: ${selectedCandidate?.score})`);
    
    // Phase 2: Research + Online Search
    thinking.push(`◈ [RESEARCH] Analyzing intent & gathering context...`);
    const intent = deepIntentAnalysis(prompt);
    const plan = generateExecutionPlan(intent, prompt);
    thinking.push(`◈ [RESEARCH] Intent: ${intent.studio} | Complexity: ${intent.complexity}`);
    
    // Phase 3: Continuous Learning
    thinking.push(`◈ [LEARN] Fetching online knowledge...`);
    try {
      onlineKnowledge = await continuousLearner.learn(prompt);
    } catch (e) {
      console.warn('Online learning skipped:', e);
    }
    thinking.push(`◈ [LEARN] Knowledge base: ${continuousLearner.getKnowledgeBaseSize()} entries`);
    
    // Phase 4: Math/Logic Verification
    thinking.push(`◈ [VERIFY] Checking math & logic...`);
    mathResult = mathVerifier.verify(prompt + ' ' + (selectedCandidate?.content || ''));
    thinking.push(`◈ [VERIFY] Math check: ${mathResult.valid ? 'PASS' : 'ISSUES_FOUND'}`);
    
    // Phase 5: Text Correction
    thinking.push(`◈ [CORRECT] Applying text corrections...`);
    const textCorrectResult = autoCorrectText(prompt);
    thinking.push(`◈ [CORRECT] ${textCorrectResult.changes.length} corrections applied`);
    
    // Phase 6: File Generation
    thinking.push(`◈ [FILES] Generating project structure...`);
    const fileContents = generateFileStructure(prompt, intent);
    thinking.push(`◈ [FILES] Created ${fileContents.length} files with full content`);
    
    // Phase 7: Top-5 Selection
    thinking.push(`◈ [TOP5] Scoring 5 candidates with diversity...`);
    const topFive = await selectTopFive(prompt);
    thinking.push(`◈ [TOP5] Top scorer: ${topFive[0]?.id} (${topFive[0]?.totalScore} pts)`);
    
    // Phase 8: Self-Correction Memory
    thinking.push(`◈ [MEMORY] Checking correction history...`);
    const similarFailures = correctionMemory.getSimilarFailures(prompt);
    thinking.push(`◈ [MEMORY] ${similarFailures.length} similar past issues found`);
    
    // Phase 9: Refinement Loop
    thinking.push(`◈ [REFINE] Running 3x improvement cycle...`);
    const refinedFiles = await improvementLoop(fileContents, { prompt, path: ANGEH_QUANTUM_PATH });
    thinking.push(`◈ [REFINE] Refinement complete: ${refinedFiles.length} files`);
    
    // Phase 10: Questioning
    thinking.push(`◈ [QUESTIONS] Validating with deep questions...`);
    const questions = await questioningLoop(prompt, {});
    thinking.push(`◈ [QUESTIONS] ${questions.length} validation questions generated`);
    
    // Phase 11: Quality Control
    thinking.push(`◈ [QC] Running quality gates...`);
    const qc = qualityControl(refinedFiles, { prompt });
    thinking.push(`◈ [QC] Final score: ${qc.score}/100`);
    
    // Phase 12: Complete
    const totalTime = Date.now() - startTime;
    thinking.push(`◈ [COMPLETE] All phases finished in ${totalTime}ms`);
    
    // Try to get real LLM response with search context
    let llmResponse = await callNativeLLM(`You are Angehlang Universe OS - an advanced AI assistant. 
User request: ${prompt}

Context from web search:
${onlineKnowledge.content?.substring(0, 1000) || 'No external knowledge available'}

Provide a helpful, detailed response.`) || '';
    
    // Build response
    let response = '';
    if (llmResponse) {
      response = llmResponse;
    } else {
      response = `## ✅ Autonomous Process Complete

### ⚡ Computing System: ACTIVE
### 📂 Angeh Path: ${ANGEH_QUANTUM_PATH}

### 📊 Process Summary (${totalTime}ms)
${thinking.map(t => t.replace('◈ ', '- ')).join('\n')}

### 🏆 Top-5 Results (Ranked by Score)
${topFive.map((t, i) => `${i+1}. **${t.id}** - Score: ${t.totalScore}/100 (P:${t.perfectionistScore}, E:${t.engineerScore})`).join('\n')}

### 📁 Generated Files (${fileContents.length} files)
- Full project structure created
- Each file contains detailed implementation
- Context-aware with quantum storage references

### 🎯 Selected Best Solution
**${selectedCandidate?.id || 'N/A'}** | Score: ${selectedCandidate?.score || 0}/100
${selectedCandidate?.content || prompt}

### ✏️ Text Corrections
${textCorrectResult.changes.length > 0 ? textCorrectResult.changes.join(', ') : 'None needed'}

### 🧮 Math/Logic Verification
${mathResult.valid ? '✓ All checks passed' : 'Issues: ' + mathResult.errors.join(', ')}

### 📚 Online Knowledge Sources
${onlineKnowledge.content?.substring(0, 200) || 'No external knowledge'}`;

    // Convert files
    const convertToVirtualFile = (fc: FileContent): VirtualFile => ({
      name: fc.name,
      type: fc.type,
      content: fc.body,
      children: fc.children?.map(convertToVirtualFile)
    });
    const virtualFiles = fileContents.map(convertToVirtualFile);

    return { 
      response, 
      thinking, 
      type: 'text' as const, 
      leadAgentId: 'ENGINEER', 
      virtualFiles,
      plan,
      topSelections: topFive as any,
      isSearching: false,
      autonomousProcess: {
        id: `PROC_${Date.now()}`,
        prompt,
        phases: thinking.map((t, i) => ({ phase: t.split(']')[0].replace('◈ [', ''), status: 'completed' as const, details: t, duration: 0 })),
        selectedCandidate,
        researchData: { online: onlineKnowledge.content },
        plan,
        fileContents,
        refinementLoop: 3,
        qualityScore: qc.score,
        isComplete: true
      }
    };
  } catch (error) {
    console.error('Autonomous process error:', error);
    return {
      response: `## Error in autonomous process\n\n${error}\n\nPlease try again.`,
      thinking: [...thinking, `◈ [ERROR] ${error}`],
      type: 'text',
      leadAgentId: 'ENGINEER',
      virtualFiles: [],
      plan: [],
      topSelections: [],
      isSearching: false
    };
  }
}
